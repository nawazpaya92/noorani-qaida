{
  "expo": {
    "name": "noorani-qaida",
    "slug": "noorani-qaida",
    "version": "1.0.0",
    "orientation": "portrait",

    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,

    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#002576"
    },

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.nooraniqaida"
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F3D91"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.nooraniqaida"
    },

    "web": {
      "favicon": "./assets/favicon.png"
    },

    "plugins": [
      "expo-font",
      "expo-splash-screen"
    ]
  }
}
